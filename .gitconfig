[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[user]
	name = <name>
	email = <email>

[alias]
    yank-main = "!f() {\
        branch=$(git rev-parse --abbrev-ref HEAD) && \
        git checkout main && \
        git pull origin main && \
        git checkout \"$branch\"\
        git merge main; \
    }"
